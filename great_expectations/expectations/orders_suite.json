{
  "expectation_suite_name": "orders_suite",
  "ge_cloud_id": null,
  "meta": {
    "great_expectations_version": "0.18.0",
    "description": "Data quality expectations for olist_orders_dataset.csv"
  },
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 90000,
        "max_value": 150000
      },
      "meta": {"notes": "Olist orders dataset should have ~99k rows"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "order_id"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "customer_id"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "order_status"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "order_purchase_timestamp"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "order_id"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "customer_id"}
    },
    {
      "expectation_type": "expect_column_values_to_be_unique",
      "kwargs": {"column": "order_id"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "order_status"}
    },
    {
      "expectation_type": "expect_column_values_to_be_in_set",
      "kwargs": {
        "column": "order_status",
        "value_set": [
          "delivered",
          "shipped",
          "canceled",
          "unavailable",
          "invoiced",
          "processing",
          "created",
          "approved"
        ]
      }
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "order_purchase_timestamp"}
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "order_id",
        "regex": "^[a-f0-9]{32}$"
      },
      "meta": {"notes": "Order IDs are 32-char hex strings"}
    }
  ]
}
