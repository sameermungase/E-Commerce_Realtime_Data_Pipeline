{
  "expectation_suite_name": "order_items_suite",
  "ge_cloud_id": null,
  "meta": {
    "great_expectations_version": "0.18.0",
    "description": "Data quality expectations for olist_order_items_dataset.csv"
  },
  "expectations": [
    {
      "expectation_type": "expect_table_row_count_to_be_between",
      "kwargs": {
        "min_value": 100000,
        "max_value": 150000
      },
      "meta": {"notes": "Olist order_items dataset should have ~112k rows"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "order_id"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "order_item_id"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "product_id"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "seller_id"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "price"}
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": {"column": "freight_value"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "order_id"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "order_item_id"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "product_id"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "price"}
    },
    {
      "expectation_type": "expect_column_values_to_not_be_null",
      "kwargs": {"column": "freight_value"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "price",
        "min_value": 0,
        "max_value": 100000
      },
      "meta": {"notes": "Prices should be non-negative and within reasonable range (BRL)"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "freight_value",
        "min_value": 0,
        "max_value": 50000
      },
      "meta": {"notes": "Freight values should be non-negative"}
    },
    {
      "expectation_type": "expect_column_values_to_be_between",
      "kwargs": {
        "column": "order_item_id",
        "min_value": 1,
        "max_value": 50
      },
      "meta": {"notes": "Order item sequence numbers should be reasonable"}
    }
  ]
}
